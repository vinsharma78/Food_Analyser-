rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId (matches request.auth.uid)
    // Fields:
    //   - userId: string (required)
    //   - weight_kg: number (required)
    //   - height_cm: number (required)
    //   - age: int (required)
    //   - gender: string (required, male/female/other)
    //   - activity_level: string (required, sedentary/light/moderate/active/very_active)
    //   - daily_calorie_goal: number (required)
    //
    // Collection: meals
    // Document ID: mealId (auto-generated)
    // Fields:
    //   - userId: string (required, matches request.auth.uid)
    //   - timestamp: string (required, ISO 8601)
    //   - meal_type: string (required, breakfast/brunch/lunch/dinner/snack)
    //   - dish_name: string (required)
    //   - calories: number (required)
    //   - protein: number (required)
    //   - carbs: number (required)
    //   - fat: number (required)
    //   - total_cost: number (required)
    //   - restaurant_name: string (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isValidUserProfile(data) {
      return data.keys().hasAll(['userId', 'weight_kg', 'height_cm', 'age', 'gender', 'activity_level', 'daily_calorie_goal']) &&
             data.userId == request.auth.uid &&
             data.weight_kg is number && data.weight_kg > 0 &&
             data.height_cm is number && data.height_cm > 0 &&
             data.age is int && data.age > 0 &&
             data.gender in ['male', 'female', 'other'] &&
             data.activity_level in ['sedentary', 'light', 'moderate', 'active', 'very_active'] &&
             data.daily_calorie_goal is number && data.daily_calorie_goal > 0;
    }

    function isValidMealLog(data) {
      return data.keys().hasAll(['userId', 'timestamp', 'meal_type', 'dish_name', 'calories', 'protein', 'carbs', 'fat', 'total_cost']) &&
             data.userId == request.auth.uid &&
             data.timestamp is string &&
             data.meal_type in ['breakfast', 'brunch', 'lunch', 'dinner', 'snack'] &&
             data.dish_name is string && data.dish_name.size() > 0 && data.dish_name.size() < 100 &&
             data.calories is number && data.calories >= 0 &&
             data.protein is number && data.protein >= 0 &&
             data.carbs is number && data.carbs >= 0 &&
             data.fat is number && data.fat >= 0 &&
             data.total_cost is number && data.total_cost >= 0;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUserProfile(request.resource.data);
      allow update: if isOwner(userId) && isValidUserProfile(request.resource.data);
    }

    match /meals/{mealId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && isValidMealLog(request.resource.data);
      allow update: if isAuthenticated() && isDocOwner() && isValidMealLog(request.resource.data);
      allow delete: if isAuthenticated() && isDocOwner();
    }
  }
}
